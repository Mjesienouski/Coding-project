<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Even Parity Binary Matrix</title>
<style>
    body {
        font-family: Arial, sans-serif;
        padding: 20px;
    }

    table {
        border-collapse: collapse;
        margin-top: 15px;
    }

    td {
        width: 50px;
        height: 50px;
        text-align: center;
        border: 1px solid #ccc;
        font-size: 18px;
        font-weight: bold;
    }

    input {
        width: 45px;
        text-align: center;
        font-size: 16px;
    }

    button {
        margin-top: 10px;
        padding: 8px 16px;
        font-size: 16px;
        cursor: pointer;
    }

    .status {
        margin-top: 15px;
        white-space: pre-line;
        font-family: monospace;
    }
</style>
</head>
<body>

<h2>Even Parity Binary Matrix</h2>

<!-- INPUT GRID -->
<table id="inputGrid"></table>

<button onclick="submitMatrix()">Submit Matrix</button>

<!-- HEATMAP -->
<h3>Heatmap</h3>
<table id="heatmap"></table>

<!-- STATUS -->
<div class="status" id="status"></div>

<script>
const size = 4;

// Create empty matrix
let matrix = Array.from({ length: size }, () => Array(size).fill(0));

// Build input grid
const inputGrid = document.getElementById("inputGrid");

for (let i = 0; i < size; i++) {
    const row = document.createElement("tr");
    for (let j = 0; j < size; j++) {
        const cell = document.createElement("td");
        const input = document.createElement("input");
        input.type = "number";
        input.min = 0;
        input.max = 1;
        input.value = 0;
        input.onchange = () => matrix[i][j] = Number(input.value);
        cell.appendChild(input);
        row.appendChild(cell);
    }
    inputGrid.appendChild(row);
}

// Even parity function
function evenParity(values) {
    return values.reduce((a,b) => a + b, 0) % 2;
}

// Draw heatmap
function drawHeatmap() {
    const heatmap = document.getElementById("heatmap");
    heatmap.innerHTML = "";

    for (let i = 0; i < size; i++) {
        const row = document.createElement("tr");
        for (let j = 0; j < size; j++) {
            const cell = document.createElement("td");
            const value = matrix[i][j];

            // Simple viridis-like coloring
            cell.style.backgroundColor = value === 0 ? "#440154" : "#FDE725";
            cell.style.color = value === 0 ? "white" : "black";
            cell.textContent = value;

            row.appendChild(cell);
        }
        heatmap.appendChild(row);
    }
}

// Explain parity rules
function explainMatrix() {
    let output = [];
    let hasError = false;

    const parityRules = {
        "1,3": [[1,0],[1,1],[1,2],[3,0],[3,1],[3,2],[3,3]],
        "2,3": [[2,0],[2,1],[2,2],[3,0],[3,1],[3,2],[3,3]],
        "0,2": [[1,2],[2,2],[3,2],[0,0],[1,0],[2,0],[3,0]],
        "0,1": [[1,1],[2,1],[3,1],[0,0],[1,0],[2,0],[3,0]],
        "0,0": Array.from({length:16}, (_,k) => [Math.floor(k/4), k%4])
                .filter(([i,j]) => !(i === 0 && j === 0))
    };

    for (const key in parityRules) {
        const [r,c] = key.split(",").map(Number);
        const cells = parityRules[key];
        const values = cells.map(([i,j]) => matrix[i][j]);
        const expected = evenParity(values);
        const actual = matrix[r][c];

        if (actual !== expected) {
            hasError = true;
            output.push(`❌ Parity error at (${r},${c}) — expected ${expected}, got ${actual}`);
        } else {
            output.push(`✅ Parity correct at (${r},${c}) — value ${actual} makes sum even`);
        }
    }

    if (!hasError) {
        output.unshift("✅ Matrix is TRUE — all even parity conditions are satisfied");
    }

    return output.join("\n");
}

// Submit button handler
function submitMatrix() {
    drawHeatmap();
    document.getElementById("status").textContent = explainMatrix();
}

// Initial display
drawHeatmap();
document.getElementById("status").textContent = explainMatrix();
</script>

</body>
</html>
